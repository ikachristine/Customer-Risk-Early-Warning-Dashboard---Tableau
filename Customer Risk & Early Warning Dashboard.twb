            <column caption='Recency Days' datatype='integer' name='[recency_days]' role='measure' type='quantitative' />
            <column caption='Sales 12M' datatype='real' name='[sales_12m]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1001488028512493621]' derivation='Sum' name='[sum:Calculation_1001488028512493621:qk]' pivot='key' type='quantitative' />
