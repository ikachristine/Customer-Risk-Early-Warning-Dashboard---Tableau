  <worksheets>
    <worksheet name=' Revenue At Risk'>
      <layout-options>
        <title>
          <formatted-text />
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='saas_customer_level_tableau' name='federated.00ydtsi1hf8av31233t0s0mvmf16' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Risk Threshold' datatype='integer' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='30'>
              <calculation class='tableau' formula='30' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.00ydtsi1hf8av31233t0s0mvmf16'>
            <column caption='CF risk_bucket_param' datatype='string' name='[Calculation_1001488025297588232]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [recency_days] &lt;= INT([Parameters].[Parameter 1] / 3) THEN&#13;&#10;    &quot;Active (0–&quot; + STR(INT([Parameters].[Parameter 1] / 3)) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] THEN&#13;&#10;    &quot;Warm (&quot; + STR(INT([Parameters].[Parameter 1] / 3) + 1) + &quot;–&quot; + STR([Parameters].[Parameter 1]) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] * 2 THEN&#13;&#10;    &quot;At-risk (&quot; + STR([Parameters].[Parameter 1] + 1) + &quot;–&quot; + STR([Parameters].[Parameter 1] * 2) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] * 4 THEN&#13;&#10;    &quot;High risk (&quot; + STR([Parameters].[Parameter 1] * 2 + 1) + &quot;–&quot; + STR([Parameters].[Parameter 1] * 4) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Churned (&gt;&quot; + STR([Parameters].[Parameter 1] * 4) + &quot;)&quot;&#13;&#10;END' />
            </column>
            <column caption='CF Revenue At Risk' datatype='real' name='[Calculation_1001488026743402522]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;    IF CONTAINS([Calculation_1001488025297588232], &quot;At-risk&quot;)&#13;&#10;       OR CONTAINS([Calculation_1001488025297588232], &quot;High risk&quot;)&#13;&#10;    THEN [sales_12m]&#13;&#10;    END&#13;&#10;)' />
            </column>
            <column caption='Total Revenue' datatype='real' name='[Calculation_1001488028511932466]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : SUM([sales_12m]) }' />
            </column>
            <column caption='Revenue At-Risk ' datatype='real' name='[Calculation_1001488028512063539]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF [recency_days] &gt; [Parameters].[Parameter 1]&#13;&#10;        THEN [sales_12m]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
            </column>
            <column caption='% Revenue At-Risk ' datatype='real' name='[Calculation_1001488028512493621]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_1001488028512063539]) / [Calculation_1001488028511932466]' />
            </column>
