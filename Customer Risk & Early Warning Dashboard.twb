          </datasource-dependencies>
          <datasource-dependencies datasource='federated.00ydtsi1hf8av31233t0s0mvmf16'>
            <column caption='CF risk_bucket_param' datatype='string' name='[Calculation_1001488025297588232]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [recency_days] &lt;= INT([Parameters].[Parameter 1] / 3) THEN&#13;&#10;    &quot;Active (0–&quot; + STR(INT([Parameters].[Parameter 1] / 3)) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] THEN&#13;&#10;    &quot;Warm (&quot; + STR(INT([Parameters].[Parameter 1] / 3) + 1) + &quot;–&quot; + STR([Parameters].[Parameter 1]) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] * 2 THEN&#13;&#10;    &quot;At-risk (&quot; + STR([Parameters].[Parameter 1] + 1) + &quot;–&quot; + STR([Parameters].[Parameter 1] * 2) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] * 4 THEN&#13;&#10;    &quot;High risk (&quot; + STR([Parameters].[Parameter 1] * 2 + 1) + &quot;–&quot; + STR([Parameters].[Parameter 1] * 4) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Churned (&gt;&quot; + STR([Parameters].[Parameter 1] * 4) + &quot;)&quot;&#13;&#10;END' />
            </column>
            <column caption='KPI Churned Customers' datatype='integer' name='[Calculation_1001488026742886425]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF CONTAINS([Calculation_1001488025297588232], &quot;Churned&quot;)&#13;&#10;    THEN [Customer ID]&#13;&#10;    END&#13;&#10;)' />
            </column>
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column datatype='integer' name='[Customer ID]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Region]' role='dimension' type='nominal' />
            <column datatype='string' name='[Segment]' role='dimension' type='nominal' />
            <column-instance column='[Country]' derivation='None' name='[none:Country:nk]' pivot='key' type='nominal' />
            <column-instance column='[Region]' derivation='None' name='[none:Region:nk]' pivot='key' type='nominal' />
            <column-instance column='[Segment]' derivation='None' name='[none:Segment:nk]' pivot='key' type='nominal' />
            <column caption='Recency Days' datatype='integer' name='[recency_days]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1001488026742886425]' derivation='User' name='[usr:Calculation_1001488026742886425:qk]' pivot='key' type='quantitative' />
