      <aliases enabled='yes' />
      <column caption='CF abs_profit_12m' datatype='real' name='[Calculation_1001488025008881664]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([profit_12m])' />
      </column>
      <column caption='CF risk_rate' datatype='real' name='[Calculation_1001488025009659905]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([recency_days]&gt; 90, 1, 0)) / COUNTD([Customer ID])' />
      </column>
      <column caption='CF cust_count_country' datatype='integer' name='[Calculation_1001488025010630658]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Country] : COUNTD([Customer ID]) }' />
      </column>
      <column caption='CF risk_group' datatype='string' name='[Calculation_1001488025011113987]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [recency_days] &gt; 90 THEN &quot;Risk (&gt;90d)&quot;&#13;&#10;ELSE &quot;Active/Warm (&lt;=90d)&quot;&#13;&#10;END' />
      </column>
      <column caption='CF is_risk_param' datatype='integer' name='[Calculation_1001488025016520708]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [recency_days] &gt; [Parameters].[Parameter 1] THEN 1 ELSE 0 END' />
      </column>
      <column caption='CF risk_group_param' datatype='string' name='[Calculation_1001488025016840197]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [recency_days] &gt; [Parameters].[Parameter 1] THEN &quot;Risk&quot;&#13;&#10;ELSE &quot;Active/Warm&quot;&#13;&#10;END' />
      </column>
      <column caption='CF risk_rate_param' datatype='real' name='[Calculation_1001488025017069574]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Calculation_1001488025016520708] = 1  THEN [Customer ID] END) / COUNTD([Customer ID])' />
      </column>
      <column caption='CF risk_bucket_param' datatype='string' name='[Calculation_1001488025297588232]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [recency_days] &lt;= INT([Parameters].[Parameter 1] / 3) THEN&#13;&#10;    &quot;Active (0–&quot; + STR(INT([Parameters].[Parameter 1] / 3)) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] THEN&#13;&#10;    &quot;Warm (&quot; + STR(INT([Parameters].[Parameter 1] / 3) + 1) + &quot;–&quot; + STR([Parameters].[Parameter 1]) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] * 2 THEN&#13;&#10;    &quot;At-risk (&quot; + STR([Parameters].[Parameter 1] + 1) + &quot;–&quot; + STR([Parameters].[Parameter 1] * 2) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] * 4 THEN&#13;&#10;    &quot;High risk (&quot; + STR([Parameters].[Parameter 1] * 2 + 1) + &quot;–&quot; + STR([Parameters].[Parameter 1] * 4) + &quot;)&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Churned (&gt;&quot; + STR([Parameters].[Parameter 1] * 4) + &quot;)&quot;&#13;&#10;END' />
      </column>
      <column caption='CF bucket_order' datatype='integer' name='[Calculation_1001488025303457801]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [recency_days] &lt;= INT([Parameters].[Parameter 1] / 3) THEN 1&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] THEN 2&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] * 2 THEN 3&#13;&#10;ELSEIF [recency_days] &lt;= [Parameters].[Parameter 1] * 4 THEN 4&#13;&#10;ELSE 5&#13;&#10;END' />
      </column>
      <column caption='CF topN_recency' datatype='boolean' name='[Calculation_1001488025334697994]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([recency_days]), &apos;desc&apos;) &lt;= 3'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='CF TopN Index' datatype='boolean' name='[Calculation_1001488025711349774]' role='measure' type='nominal'>
        <calculation class='tableau' formula='INDEX() &lt;= 3'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='CF TopN Country' datatype='boolean' name='[Calculation_1001488026027610129]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK_DENSE([Calculation_1001488025017069574], &apos;desc&apos;) &lt;= [Parameters].[Parameter 3]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='KPI Total Customers' datatype='integer' default-format='N' name='[Calculation_1001488026045878291]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Customer ID])' />
      </column>
      <column caption='KPI Active Customers' datatype='integer' name='[Calculation_1001488026046062612]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [Calculation_1001488025016520708] = 0 THEN [Customer ID]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='KPI At risk Customers' datatype='integer' name='[Calculation_1001488026046234645]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [Calculation_1001488025016520708] = 1 THEN [Customer ID]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='KPI Risk Rate' datatype='real' default-format='p0.0%' name='[Calculation_1001488026046398486]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Calculation_1001488025016520708] = 1 THEN [Customer ID] END)&#13;&#10;/ &#13;&#10;COUNTD([Customer ID])' />
      </column>
      <column caption='CF Risk Bucket (Customer)' datatype='string' name='[Calculation_1001488026052042775]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [Customer ID] : MIN([Calculation_1001488025297588232]) }' />
      </column>
      <column caption='KPI High Risk Customers' datatype='integer' name='[Calculation_1001488026741911576]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF CONTAINS([Calculation_1001488025297588232], &quot;High risk&quot;)&#13;&#10;    THEN [Customer ID]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='KPI Churned Customers' datatype='integer' name='[Calculation_1001488026742886425]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF CONTAINS([Calculation_1001488025297588232], &quot;Churned&quot;)&#13;&#10;    THEN [Customer ID]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='CF Revenue At Risk' datatype='real' name='[Calculation_1001488026743402522]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF CONTAINS([Calculation_1001488025297588232], &quot;At-risk&quot;)&#13;&#10;       OR CONTAINS([Calculation_1001488025297588232], &quot;High risk&quot;)&#13;&#10;    THEN [sales_12m]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='CF Risk Rate by Segment' datatype='real' name='[Calculation_1001488026744643611]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF CONTAINS([Calculation_1001488025297588232], &quot;risk&quot;)&#13;&#10;    THEN [Customer ID]&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD([Customer ID])' />
      </column>
      <column caption='CF Risk Rate by Region' datatype='real' name='[Calculation_1001488026746425372]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF CONTAINS([Calculation_1001488025297588232], &quot;risk&quot;)&#13;&#10;    THEN [Customer ID]&#13;&#10;    END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD([Customer ID])' />
      </column>
      <column caption='CF Risk Group ' datatype='string' name='[Calculation_1001488026782187550]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([Calculation_1001488025297588232], &quot;Active&quot;)&#13;&#10;   OR CONTAINS([Calculation_1001488025297588232], &quot;Warm&quot;)&#13;&#10;THEN &quot;Active&quot;&#13;&#10;&#13;&#10;ELSE &quot;Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='CF jumlah customer' datatype='integer' name='[Calculation_1001488026783944735]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Customer ID])' />
      </column>
      <column caption='CF Avg Discount Risk' datatype='real' name='[Calculation_1001488026785370145]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;    IF [Calculation_1001488026782187550] = &quot;Risk&quot;&#13;&#10;    THEN [avg_discount]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='CF Avg Discount Active' datatype='real' name='[Calculation_1001488026785529890]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;    IF [Calculation_1001488026782187550] = &quot;Active&quot;&#13;&#10;    THEN [avg_discount]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='CF Discount Gap' datatype='real' name='[Calculation_1001488026785726499]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1001488026785370145] - [Calculation_1001488026785529890]' />
      </column>
      <column caption='CF Quadrant' datatype='string' name='[Calculation_1001488027448766502]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([recency_days]) &gt; [Parameters].[Parameter 1]&#13;&#10;AND SUM([sales_12m]) &gt; WINDOW_MEDIAN(SUM([sales_12m]))&#13;&#10;THEN &quot;High Value At Risk&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([recency_days]) &gt; [Parameters].[Parameter 1]&#13;&#10;THEN &quot;Low Value At Risk&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([sales_12m]) &gt; WINDOW_MEDIAN(SUM([sales_12m]))&#13;&#10;THEN &quot;High Value Active&quot;&#13;&#10;&#13;&#10;ELSE &quot;Low Value Active&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='CF Global Median Revenue' datatype='real' name='[Calculation_1001488028500525097]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MEDIAN([sales_12m]) }' />
      </column>
      <column caption='High Value Active' datatype='string' name='[Calculation_1001488028503257131]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;High Value Active&quot;' />
      </column>
      <column caption='Low Value Active' datatype='string' name='[Calculation_1001488028504088620]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Low Value Active&quot;' />
      </column>
      <column caption='High Value At Risk' datatype='string' name='[Calculation_1001488028504145965]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;High Value At Risk&quot;' />
      </column>
      <column caption='Low Value At Risk' datatype='string' name='[Calculation_1001488028504248366]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Low Value At Risk&quot;' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_1001488028511932466]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM([sales_12m]) }' />
      </column>
      <column caption='Revenue At-Risk ' datatype='real' name='[Calculation_1001488028512063539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF [recency_days] &gt; [Parameters].[Parameter 1]&#13;&#10;        THEN [sales_12m]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='% Revenue At-Risk ' datatype='real' name='[Calculation_1001488028512493621]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1001488028512063539]) / [Calculation_1001488028511932466]' />
      </column>
      <column caption='Risk Group Simple' datatype='string' name='[Calculation_1001488028516118584]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([recency_days]) &gt; [Parameters].[Parameter 1]&#13;&#10;THEN &quot;At Risk&quot;&#13;&#10;ELSE &quot;Active&quot;&#13;&#10;END' />
      </column>
      <column caption='HV At Risk Flag' datatype='string' name='[Calculation_1001488028516696121]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1001488027448766502] = &quot;High Value At Risk&quot;&#13;&#10;THEN &quot;Priority&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Priority Score' datatype='real' name='[Calculation_1001488028521963580]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales_12m]) * SUM([recency_days])' />
      </column>
      <column caption='High Value At Risk Flag ' datatype='integer' name='[Calculation_1001488028522115133]' role='measure' type='quantitative'>
